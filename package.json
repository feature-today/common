{
  "name": "@feature-today/common",
  "version": "0.0.0",
  "description": "Shared TypeScript library for feature-today: types, UI components and helpers consumed by `my` and `website`.",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/feature-today/common.git"
  },
  "private": false,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint.fix": "oxlint --fix",
    "fmt": "oxlint --fix",
    "fmt.check": "oxlint",
    "test": "vitest run",
    "test.watch": "vitest",
    "test.coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "oxlint": "^1.0.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.4.0"
}